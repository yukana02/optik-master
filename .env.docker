APP_NAME="Optik Store"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://optik.domain-anda.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=optik_store
DB_USERNAME=optik_user
DB_PASSWORD=optik_password_123

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=log
